# Clawde — config example.
# Cópia: cp config/clawde.toml.example ~/.clawde/config/clawde.toml
#
# Todos os campos têm default sane; remova o que não quer customizar.
# Schema autoritativo: src/config/schema.ts (zod, validado no boot).

[clawde]
home      = "~/.clawde"
log_level = "INFO"   # TRACE | DEBUG | INFO | WARN | ERROR | FATAL

[worker]
max_parallel            = 1                          # 1 worker por vez (Max evita serial cost)
cli_path                = "/usr/local/bin/claude"
cli_min_version         = "2.0.0"
default_max_turns       = 15
default_timeout_seconds = 1800                        # 30min hard cap por task
lease_seconds           = 600                         # 10min lease, renovado por heartbeat
heartbeat_seconds       = 60

[receiver]
listen_tcp        = "127.0.0.1:18790"
listen_unix       = "/run/clawde/receiver.sock"
unix_socket_mode  = "0660"
unix_socket_group = "clawde"

[receiver.rate_limit]
per_ip_per_minute = 10
per_ip_per_hour   = 100
health_per_minute = 60

[quota]
plan                = "max5x"        # pro | max5x | max20x
window_hours        = 5
reserve_urgent_pct  = 15             # reserva 15% pra URGENT em peak
peak_hours_tz       = "America/Los_Angeles"
peak_start_local    = "05:00"
peak_end_local      = "11:00"
peak_multiplier     = 1.7            # consumo virtual em peak hours

[quota.thresholds]
aviso    = 60
restrito = 80
critico  = 95

[sandbox]
default_level             = 1                                          # 1 (systemd) | 2 (+bwrap) | 3 (+netns)
bwrap_path                = "/usr/bin/bwrap"
allow_levels_per_agent    = true
egress_allowlist_path     = "~/.clawde/config/egress_allowlist.txt"

[memory]
backend                  = "native"                          # native | claude-mem-deprecated
jsonl_root               = "~/.claude/projects"
indexer_interval_minutes = 10
embeddings_enabled       = false                             # opt-in: bun add @xenova/transformers
embeddings_model         = "Xenova/multilingual-e5-small"

[auth]
oauth_token_source      = "env"                # env | systemd-credential | keychain
oauth_token_credential  = "clawde-oauth"       # nome do credential ou env var
oauth_expiry_warn_days  = 30
oauth_auto_refresh      = true                  # quando 401, dispara setup-token e retenta 1x

# === Telegram (Fase 6) — opcional ===
# Pra ativar: defina secret + allowed_user_ids e chame setWebhook do Telegram
# apontando pra https://<seu-host>:18790/webhook/telegram com X-Telegram-Bot-Api-Secret-Token=<secret>.
# [telegram]
# secret             = "from-setwebhook-call"
# allowed_user_ids   = [42, 1234]
# default_priority   = "NORMAL"
# default_agent      = "telegram-bot"

# === Litestream (Fase 8) — opcional ===
# Configurado fora do clawde.toml em deploy/litestream/litestream.yml.
# Apenas referência aqui pra clawde replica saber qual replicas verificar.
# [replica]
# expected_replicas = ["b2"]
# max_age_minutes   = 90

# === Review pipeline (Fase 9) — opcional ===
# Por agente em .clawde/agents/<nome>/sandbox.toml
# [review]
# review_required        = false      # liga pipeline de review
# stages                 = ["implementer", "spec-reviewer", "code-quality-reviewer"]
# max_retries_per_stage  = 2
