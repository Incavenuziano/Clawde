# Normalize line endings to LF in repo, regardless of OS.
# Working tree on Windows can keep CRLF if user wants — git stores LF.
* text=auto eol=lf

# Source code: always LF.
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.mjs      text eol=lf
*.json     text eol=lf
*.toml     text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.sql      text eol=lf
*.md       text eol=lf
*.sh       text eol=lf
*.service  text eol=lf
*.timer    text eol=lf
*.path     text eol=lf

# Binary files: never normalize.
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.gz       binary
*.tgz      binary
*.zip      binary
*.lock     binary
