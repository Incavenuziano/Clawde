{
  "name": "clawde",
  "version": "0.0.1",
  "description": "Personal task daemon using Claude Code headless via Max subscription",
  "private": true,
  "type": "module",
  "bin": {
    "clawde": "./dist/clawde"
  },
  "license": "AGPL-3.0-or-later",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "build": "bun build src/cli/main.ts --compile --outfile dist/clawde",
    "ci": "bun run typecheck && bun run lint && bun run test"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/bun": "1.3.6",
    "typescript": "5.7.3"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.123",
    "smol-toml": "1.6.1",
    "zod": "4.3.6"
  }
}
